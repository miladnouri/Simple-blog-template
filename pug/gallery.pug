extends layout/_layout

block variables
    - var pageTitle = "گالری"

block content


    section.card
       
        h2 گالری (مثلا لیست مصاحبه‌ها)

        .gallery

            //- Gallery Photos
            - for (var i = 1; i <= 6; i++)
                div.photo
                    a(href="#" target="_blank")
                        img(src=`https://picsum.photos/800/200?random=+${i}`, alt=`تصویر ${i}`)
                        div.caption
                            h3= `عنوان تصویر ${i}`
                            p= `۲۲ مهر ۱۴۰۲`
